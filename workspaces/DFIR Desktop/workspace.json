{
  "friendly_name": "DFIR Desktop",
  "description": "Digital forensics workstation with Autopsy, Ghidra, Volatility3, Wireshark, CyberChef, and more.",
  "docker_registry": "https://ghcr.io/",
  "image_src": "dfir-desktop.svg",
  "categories": [
    "Security",
    "Development"
  ],
  "architecture": [
    "amd64"
  ],
  "run_config": {
    "hostname": "kasm"
  },
  "exec_config": {
    "cap_add": ["NET_RAW", "NET_ADMIN", "SYS_PTRACE"]
  },
  "compatibility": [
    {
      "version": "1.19.x",
      "image": "ghcr.io/sharrison-sans/kasm-dfir-desktop:stable",
      "uncompressed_size_mb": 5200,
      "available_tags": [
        "stable",
        "develop"
      ]
    }
  ]
}
