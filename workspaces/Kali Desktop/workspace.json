{
  "friendly_name": "Kali Desktop",
  "description": "Penetration testing lab with kali-tools-top10, Metasploit, Nmap, and Burp Suite.",
  "docker_registry": "https://ghcr.io/",
  "image_src": "kali-desktop.svg",
  "categories": [
    "Security"
  ],
  "architecture": [
    "amd64"
  ],
  "run_config": {
    "hostname": "kasm"
  },
  "exec_config": {
    "cap_add": ["NET_RAW", "NET_ADMIN", "SYS_PTRACE"]
  },
  "compatibility": [
    {
      "version": "1.19.x",
      "image": "ghcr.io/sharrison-sans/kasm-kali-desktop:stable",
      "uncompressed_size_mb": 9800,
      "available_tags": [
        "stable",
        "develop"
      ]
    }
  ]
}
